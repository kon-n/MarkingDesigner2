<UserControl x:Class="MarkingDesigner.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:bh="clr-namespace:MarkingDesigner.Behaviors"
             xmlns:cv="clr-namespace:MarkingDesigner.Converters"
             xmlns:vm="clr-namespace:MarkingDesigner.ViewModels"
             xmlns:models="clr-namespace:MarkingDesigner.Models"
             xmlns:ctrl="clr-namespace:MarkingDesigner.Views.Controls">
    <UserControl.Resources>
        <cv:MmToDipConverter x:Key="mm2dip"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <cv:NullToVisibilityConverter x:Key="NullToVis"/>
        <cv:IntVClampConverter x:Key="IntVClamp"/>
        <cv:TwoDCodeImageConverter x:Key="TwoDCodeImage"/>

        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="5" Opacity="0.4" Color="Black"/>

        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding PrevSeqCommand}" 
                        Content="{DynamicResource Str_Prev}" 
                        Width="120" Height="40" FontSize="14" FontWeight="Bold"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding Sequences}" SelectedItem="{Binding CurrentSequence}"
                          DisplayMemberPath="Title" Margin="10,0" Height="40" FontSize="18" VerticalContentAlignment="Center" FontWeight="Bold"/>

                <Button Grid.Column="2" Command="{Binding NextSeqCommand}" 
                        Content="{DynamicResource Str_Next}" 
                        Width="120" Height="40" FontSize="14" FontWeight="Bold"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource PanelBackBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="150"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="230"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding CurrentSequence.Entries}" SelectedItem="{Binding SelectedSequenceEntry, Mode=TwoWay}"
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="{DynamicResource PanelBackBrush}" 
                          BorderThickness="0" HeadersVisibility="Column"
                          FontSize="14"
                          RowBackground="{DynamicResource PanelBackBrush}"
                          AlternatingRowBackground="{DynamicResource WindowBackBrush}"
                          Foreground="{DynamicResource TextBrush}"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">

                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource PanelBackBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.ItemContainerStyle>

                    <i:Interaction.Behaviors>
                        <bh:ScrollIntoViewBehavior/>
                    </i:Interaction.Behaviors>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Str_HeaderID}" Binding="{Binding UiJobIdLabel}" Width="36" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                        <DataGridTextColumn Header="{DynamicResource Str_HeaderName}" Binding="{Binding UiJobNameLabel}" Width="90" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                        <DataGridTextColumn Header="{DynamicResource Str_HeaderText}" Binding="{Binding UiJobTextLabel}" Width="72" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                        <DataGridTemplateColumn Header="{DynamicResource Str_HeaderSeqRole}" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.SequenceRoleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedValue="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Role">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Str_Header2DKind}" Binding="{Binding UiTwoDKindLabel, Mode=OneWay}" Width="44" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                        <DataGridTextColumn Header="{DynamicResource Str_Header2DV}" Binding="{Binding UiSymbolVLabel, Mode=OneWay}" Width="36" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                        <DataGridTextColumn Header="{DynamicResource Str_Header2DSrc}" Binding="{Binding UiTwoDSrcLabel, Mode=OneWay}" Width="40" IsReadOnly="True" ElementStyle="{StaticResource CellTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                    <Button Command="{Binding MoveSequenceEntryUpCommand}" Width="100" Height="28" Margin="2" Content="{DynamicResource Str_BtnSeqUp}"/>
                    <Button Command="{Binding MoveSequenceEntryDownCommand}" Width="100" Height="28" Margin="2" Content="{DynamicResource Str_BtnSeqDown}"/>
                </StackPanel>

                <Border Grid.Row="2" Padding="5" Background="{DynamicResource WindowBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Str_LabelSeqRole}" Foreground="{DynamicResource TextBrush}" Margin="2,0,2,0" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding SequenceRoleOptions}" SelectedValue="{Binding RoleToAdd}" SelectedValuePath="Role" Margin="0,0,0,4" Height="32" FontSize="13" VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource Str_HintSeqRolePerRow}" FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="2,0,2,10" Opacity="0.9"/>

                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RoleToAddNeedsJobPicker}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{DynamicResource Str_LabelPlacementJob}" Foreground="{DynamicResource TextBrush}" Margin="2"/>
                            <TextBlock Text="{DynamicResource Str_HintJobPickerUsage}" FontSize="11" Foreground="{DynamicResource TextBrush}" Margin="2,0,2,4" Opacity="0.9"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox ItemsSource="{Binding AllJobs}" SelectedItem="{Binding JobToAdd}"
                                          Height="40" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,5,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding JobId, StringFormat='ID:{0}'}" FontWeight="Bold" Width="50"/>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text=" - "/>
                                                <TextBlock Text="{Binding Marking.Text}" Foreground="Gray"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RoleToAddSupportsSourceJobs}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Background="{DynamicResource PanelBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                                <StackPanel>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RoleToAddIsTwoD}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{DynamicResource Str_LabelTwoDBlockTitle}" Foreground="{DynamicResource SelectionBrush}" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="{DynamicResource Str_LabelTwoDKind}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding TwoDSymbolOptions}" SelectedValue="{Binding TwoDSymbolKindToAdd}" SelectedValuePath="Kind" Margin="0,0,0,8" Height="28" FontSize="13" IsEnabled="False">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Label}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="{DynamicResource Str_LabelSymbolSizeV}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding SymbolSizeVToAdd, UpdateSourceTrigger=LostFocus, Converter={StaticResource IntVClamp}}" Margin="0,0,0,10" Height="26" FontSize="14" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{DynamicResource Str_LabelTwoDSource}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource Str_HintTwoDSource}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextBrush}" Margin="0,0,6,0"/>
                                        <Button Grid.Column="1" Command="{Binding AddTwoDSourceJobCommand}" Content="{DynamicResource Str_BtnAddTwoDSource}" Padding="8,4"/>
                                    </Grid>
                                    <ListBox ItemsSource="{Binding TwoDSourceJobsToAdd}" MaxHeight="80" Background="{DynamicResource WindowBackBrush}" Foreground="{DynamicResource TextBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                                        <Run Text="{Binding JobId, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Button Grid.Column="1" Content="{DynamicResource Str_BtnRemove}" Padding="6,4"
                                                            Command="{Binding DataContext.RemoveTwoDSourceJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="{DynamicResource Str_HintMultipleTwoD}" FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button Command="{Binding AddJobCommand}" Height="35" Background="#2E7D32" Foreground="White" BorderThickness="0" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource Str_BtnAdd}" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding DeleteJobCommand}" Height="35" Background="#C62828" Foreground="White" BorderThickness="0" Margin="0,5,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource Str_BtnRemove}" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}"/>

            <ScrollViewer Grid.Column="2" Background="{DynamicResource WindowBackBrush}" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          x:Name="MainScrollViewer">

                <!-- 常に中央に配置するための外側コンテナ -->
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <!-- 拡大縮小の対象となるコンテナ。Center指定で中央に寄せる -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Margin="100">
                        <Grid Background="{DynamicResource CanvasBackBrush}" 
                              Effect="{StaticResource DropShadowEffect}">
                            <Grid.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                            </Grid.LayoutTransform>

                            <ItemsControl ItemsSource="{Binding CurrentSequence.LinkSegments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="{Binding Device.RangeX, Converter={StaticResource mm2dip}}" 
                                                Height="{Binding Device.RangeY, Converter={StaticResource mm2dip}}" 
                                                Background="Transparent"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding StartX, Converter={StaticResource mm2dip}}"/>
                                        <Setter Property="Canvas.Bottom"  Value="{Binding StartY, Converter={StaticResource mm2dip}}"/>
                                        <Setter Property="Panel.ZIndex" Value="1"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.LayoutTransform>
                                                <ScaleTransform ScaleY="-1"/>
                                            </Grid.LayoutTransform>
                                            <Line X1="0" Y1="0"
                                                  X2="{Binding DeltaX, Converter={StaticResource mm2dip}}"
                                                  Y2="{Binding DeltaY, Converter={StaticResource mm2dip}}"
                                                  Stroke="#AA607D8B"
                                                  StrokeThickness="1.2"
                                                  StrokeDashArray="4,3"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding CurrentSequence.Entries}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="{Binding Device.RangeX, Converter={StaticResource mm2dip}}" 
                                                Height="{Binding Device.RangeY, Converter={StaticResource mm2dip}}" 
                                                Background="Transparent"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Job.StartX, Converter={StaticResource mm2dip}}"/>
                                        <Setter Property="Canvas.Bottom"  Value="{Binding Job.StartY, Converter={StaticResource mm2dip}}"/>
                                        <Setter Property="Panel.ZIndex" Value="{Binding Job.JobId}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Job.IsSelected}" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="9999"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Job}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.RenderTransform>
                                                <TranslateTransform X="{Binding Job.OffsetX, Converter={StaticResource mm2dip}}" 
                                                                    Y="{Binding Job.OffsetY, Converter={StaticResource mm2dip}}"/>
                                            </Grid.RenderTransform>
                                            <!-- Visual Layer: LayoutTransform enables proper layout sizing after flip -->
                                            <Border x:Name="Bd" 
                                                    BorderThickness="1" 
                                                    BorderBrush="Transparent" 
                                                    Background="Transparent" 
                                                    Padding="2">

                                                <Border.LayoutTransform>
                                                    <ScaleTransform ScaleY="-1"/>
                                                </Border.LayoutTransform>
                                                <Grid>
                                                    <ctrl:MarkingObject x:Name="MarkingCtrl" Text="{Binding Job.Marking.Text}" FontType="{Binding Job.Font}"
                                                                        CharHeight="{Binding Job.Height}"
                                                                        PitchX="{Binding Job.PitchX}"
                                                                        PitchY="{Binding Job.PitchY}"
                                                                        RotationType="{Binding Job.RotationType}"
                                                                        Stroke="{Binding Job.Stroke}" StrokeThickness="1"/>
                                                    <Image x:Name="TwoDImage"
                                                           Source="{Binding Converter={StaticResource TwoDCodeImage}}"
                                                           Stretch="Fill"
                                                           Width="{Binding SymbolSizeV, Converter={StaticResource mm2dip}}"
                                                           Height="{Binding SymbolSizeV, Converter={StaticResource mm2dip}}"
                                                           Visibility="Collapsed"/>
                                                </Grid>
                                            </Border>

                                            <!-- Move Handle Layer: Outside the flip to simplify mouse interaction -->
                                            <Thumb Opacity="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <i:Interaction.Behaviors>
                                                    <bh:ElementMoveBehavior 
                                                        PositionX="{Binding Job.StartX, Mode=TwoWay}" 
                                                        PositionY="{Binding Job.StartY, Mode=TwoWay}"
                                                        ZoomScale="{Binding DataContext.ZoomScale, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </i:Interaction.Behaviors>
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Rectangle Fill="Transparent"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>

                                            <!-- Resize Handle: Positioned at visual top (which is positive Y in DataTemplate Grid) -->
                                            <Thumb VerticalAlignment="Top" HorizontalAlignment="Center" Width="12" Height="12" Cursor="SizeNS" Margin="0,-6,0,0">
                                                <i:Interaction.Behaviors>
                                                    <bh:ElementResizeHeightBehavior Height="{Binding Job.Height, Mode=TwoWay}"/>
                                                </i:Interaction.Behaviors>
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Border Background="White" BorderBrush="Black" BorderThickness="1"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Grid>

                                        <DataTemplate.Triggers>
                                            <!-- Selection: Green -->
                                            <DataTrigger Binding="{Binding Job.IsSelected}" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF00FF00"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="Bd" Property="Background" Value="#2200FF00"/>
                                            </DataTrigger>
                                            <!-- Out of Bounds: Red (Overrides selection) -->
                                            <DataTrigger Binding="{Binding Job.IsOutOfBounds}" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFF0000"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="Bd" Property="Background" Value="#22FF0000"/>
                                                <Setter TargetName="MarkingCtrl" Property="Stroke" Value="#FFFF0000"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTwoDCommand}" Value="True">
                                                <Setter TargetName="MarkingCtrl" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="TwoDImage" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}"/>

            <Border Grid.Column="4" Background="{DynamicResource PanelBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Border DataContext="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext}"
                                Visibility="{Binding SelectedSequenceEntry, Converter={StaticResource NullToVis}}">
                            <StackPanel DataContext="{Binding SelectedSequenceEntry}" Margin="0,0,0,12">
                                <TextBlock Text="{DynamicResource Str_SeqEntryTitle}" Foreground="{DynamicResource SelectionBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Str_LabelSeqRole}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding DataContext.SequenceRoleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Role" Margin="0,0,0,8" Height="28" FontSize="13">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SupportsSourceJobs}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Background="{DynamicResource PanelBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTwoDCommand}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="{DynamicResource Str_LabelTwoDBlockTitle}" Foreground="{DynamicResource SelectionBrush}" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                                                <TextBlock Text="{DynamicResource Str_LabelTwoDKind}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                <ComboBox ItemsSource="{Binding DataContext.TwoDSymbolOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          SelectedValue="{Binding TwoDSymbolKind, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Kind" Margin="0,0,0,8" Height="28" FontSize="13" IsEnabled="False">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{DynamicResource Str_LabelSymbolSizeV}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding SymbolSizeV, UpdateSourceTrigger=LostFocus, Converter={StaticResource IntVClamp}}" Margin="0,0,0,0" Height="26" FontSize="14" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Str_LabelTwoDSource}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource Str_HintTwoDSourceEntry}" FontSize="11" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding DataContext.AddTwoDSourceJobToEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Content="{DynamicResource Str_BtnAddTwoDSource}" Padding="8,4"/>
                                    </Grid>
                                    <ListBox ItemsSource="{Binding TwoDSourceJobs}" MaxHeight="120" Background="{DynamicResource WindowBackBrush}" Foreground="{DynamicResource TextBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                                        <Run Text="{Binding JobId, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Button Grid.Column="1" Content="{DynamicResource Str_BtnRemove}" Padding="6,4"
                                                            Command="{Binding DataContext.RemoveTwoDSourceJobFromEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel DataContext="{Binding SelectedJob}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="{DynamicResource Str_PropTitle}" Foreground="{DynamicResource SelectionBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                        <TextBlock Text="{DynamicResource Str_PropName}" Foreground="{DynamicResource TextBrush}" FontSize="14"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="25" FontSize="14" VerticalContentAlignment="Center"/>

                        <TextBlock Text="{DynamicResource Str_PropText}" Foreground="{DynamicResource TextBrush}" FontSize="14"/>
                        <TextBox Text="{Binding Marking.Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="25" FontSize="14" VerticalContentAlignment="Center"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Str_PropX}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <TextBox Text="{Binding StartX, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Str_PropY}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <TextBox Text="{Binding StartY, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Str_PropPitchX}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <TextBox Text="{Binding PitchX, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Str_PropPitchY}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <TextBox Text="{Binding PitchY, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Str_PropHeight}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Rotation" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <ComboBox SelectedIndex="{Binding RotationType}" Height="25" FontSize="12" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="0: 0°"/>
                                    <ComboBoxItem Content="1: -90°"/>
                                    <ComboBoxItem Content="2: 180°"/>
                                    <ComboBoxItem Content="3: 90°"/>
                                    <ComboBoxItem Content="4: -45°"/>
                                    <ComboBoxItem Content="5: -135°"/>
                                    <ComboBoxItem Content="6: 135°"/>
                                    <ComboBoxItem Content="7: 45°"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Font" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <ComboBox SelectedItem="{Binding Font}" 
                                          ItemsSource="{x:Static vm:JobViewModel.AllMarkingFonts}" 
                                          Height="25"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Color" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                <ComboBox SelectedValue="{Binding Stroke}" SelectedValuePath="Brush" ItemsSource="{x:Static vm:JobViewModel.AvailableColors}" Height="25">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Rectangle Width="15" Height="15" Fill="{Binding Brush}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Expander Header="Trajectory &amp; Speed" IsExpanded="True" Margin="0,5,0,5" Foreground="{DynamicResource TextBrush}">
                            <StackPanel Margin="5">
                                <TextBlock Text="Trajectory Type" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Static vm:JobViewModel.AllTrajectories}"
                                          SelectedItem="{Binding Trajectory}" Margin="0,0,0,5"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Speed" FontSize="12"/>
                                        <TextBox Text="{Binding Speed, StringFormat=N0}" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="EndX" FontSize="12"/>
                                        <TextBox Text="{Binding EndX, StringFormat=N1}" Height="25"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="EndY" FontSize="12" Margin="0,5,0,0"/>
                                <TextBox Text="{Binding EndY, StringFormat=N1}" Height="25"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Arc &amp; Shape" IsExpanded="False" Margin="0,5,0,5" Foreground="{DynamicResource TextBrush}">
                            <StackPanel Margin="5">
                                <CheckBox Content="Enable Line" IsChecked="{Binding IsLine}" Margin="0,0,0,5"/>
                                <CheckBox Content="Enable Arc" IsChecked="{Binding IsArc}" Margin="0,0,0,5"/>
                                <TextBlock Text="Arc Center X/Y" FontSize="12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding ArcCenterX, StringFormat=N1}" Height="25"/>
                                    <TextBox Grid.Column="2" Text="{Binding ArcCenterY, StringFormat=N1}" Height="25"/>
                                </Grid>
                                <TextBlock Text="Arc Angle Pitch (deg)" FontSize="12" Margin="0,5,0,0"/>
                                <TextBox Text="{Binding ArcAnglePitch, StringFormat=N1}" Height="25"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Range Settings" IsExpanded="False" Margin="0,5,0,5" Foreground="{DynamicResource TextBrush}">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="Top" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding RangeTop, StringFormat=N1}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Left" FontSize="10"/>
                                    <TextBox Text="{Binding RangeLeft, StringFormat=N1}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="Right" FontSize="10"/>
                                    <TextBox Text="{Binding RangeRight, StringFormat=N1}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="Bottom" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding RangeBottom, StringFormat=N1}"/>
                                </StackPanel>
                            </Grid>
                        </Expander>

                        <Expander Header="Advanced Increment" IsExpanded="False" Margin="0,5,0,10" Foreground="{DynamicResource TextBrush}">
                            <StackPanel Margin="5">
                                <TextBlock Text="Display Format" FontSize="12"/>
                                <ComboBox SelectedItem="{Binding IncDisplay}" ItemsSource="{x:Static vm:JobViewModel.AllIncDisplays}" Margin="0,0,0,5"/>
                                
                                <TextBlock Text="Reset Condition" FontSize="12"/>
                                <ComboBox SelectedItem="{Binding IncReset}" ItemsSource="{x:Static vm:JobViewModel.AllIncResets}" Margin="0,0,0,5"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Digits (1-10)" FontSize="12"/>
                                        <TextBox Text="{Binding IncDigits}" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Current Val" FontSize="12"/>
                                        <TextBox Text="{Binding IncCurrentValue}" Height="25"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <TextBlock Text="Calendar Settings" Foreground="{DynamicResource TextBrush}" FontSize="14"/>
                        <TextBox Text="{Binding CalendarString}" Margin="0,0,0,15" Height="25" VerticalContentAlignment="Center"/>

                        <CheckBox Content="{DynamicResource Str_PropInc}" IsChecked="{Binding Marking.IsIncrement}" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,10">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource PanelBackBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ZOOM:" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>

                <ComboBox Grid.Column="1" Width="80" VerticalContentAlignment="Center"
                          ItemsSource="{Binding ZoomPresets}" SelectedItem="{Binding ZoomScale}"
                          IsEditable="True" Text="{Binding ZoomScale, StringFormat=P0}" Margin="0,0,10,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat=P0}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Slider Grid.Column="2" Minimum="0.1" Maximum="4.0" Value="{Binding ZoomScale}" 
                        LargeChange="0.1" SmallChange="0.05" VerticalAlignment="Center" 
                        TickFrequency="0.1" IsSnapToTickEnabled="False"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>